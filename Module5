<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Dog Description</title>
</head>
<body>
  <p id="dog-description"></p>

  <script>
    // Dog object with properties, including mySound
    const dog = {
      name: "Brady Harrington",
      breed: "Golden Retriever",
      age: 3,
      color: "golden",
      mySound: "I sound very friendly and full of energy!"
    };

    // Build a message using each property
    const message = `${dog.name} is a ${dog.age}-year-old ${dog.color} ${dog.breed}. ` +
                    `When you hear me, I say: "${dog.mySound}"`;

    // Display the message to the user by putting it in the <p> element
    const descriptionElement = document.getElementById("dog-description");
    descriptionElement.textContent = message;
  </script>
</body>
</html>
